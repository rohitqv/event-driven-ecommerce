# Postgres (used in compose + alembic later)
POSTGRES_USER=ecom
POSTGRES_PASSWORD=ecom_dev_only
POSTGRES_DB=ecom
POSTGRES_PORT=5432

# Set COMPOSE_PROJECT_NAME so compose containers have a stable prefix
COMPOSE_PROJECT_NAME=ecom

# Webapp
WEBAPP_PORT=8000
DATABASE_URL=postgresql+asyncpg://ecom:ecom_dev_only@postgres:5432/ecom
